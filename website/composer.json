{
    "name": "joefallon/kissmvc",
    "type": "project",
    "description": "KissMVC is a Keep-It-Simple-Straightforward (KISS) MVC framework.",
    "keywords": [
        "MVC",
        "model-view-controller"
    ],
    "homepage": "https://github.com/joefallon/KissMVC",
    "license": "MIT",
    "authors": [
        {
            "name": "Joe Fallon",
            "email": "joseph.t.fallon@gmail.com",
            "homepage": "https://www.joefallon.net/"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-libxml": "*",
        "ext-simplexml": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "KissMVC\\": "lib/KissMVC/",
            "Controllers\\": "src/Controllers/"
        },
        "classmap": [
            "src/Bootstrapper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "find lib src tests -path '*/vendor' -prune -o -name '*.php' -print0 | xargs -0 -n1 php -l",
        "test": "@php vendor/bin/phpunit --configuration phpunit.xml.dist",
        "test:coverage": "mkdir -p build/coverage && XDEBUG_MODE=coverage vendor/bin/phpunit --configuration phpunit.xml.dist --coverage-clover build/coverage/clover.xml > /dev/null && php scripts/coverage-summary.php build/coverage/clover.xml",
        "test:coverage:orig": "@php -d xdebug.mode=coverage vendor/bin/phpunit --configuration phpunit.xml.dist --coverage-clover build/coverage/clover.xml --coverage-html build/coverage/html --coverage-text",
        "test:timing": "mkdir -p .ai/out && vendor/bin/phpunit --configuration phpunit.xml.dist --log-junit .ai/out/phpunit-junit.xml",
        "test:timing-summary": "php scripts/phpunit-timing-summary.php .ai/out/phpunit-junit.xml"
    }
}

{
    // Keep the initial run exploratory while the mutation baseline is being established.
    timeout: 60,
    source: {
        directories: [
            "lib",
            "src",
        ],
        excludes: [
            "KissMVC/ApplicationBuilder.php",
            "KissMVC/ApplicationRunnerOptions.php",
            "KissMVC/ControllerFactoryInterface.php",
            "KissMVC/DefaultFrontControllerFactory.php",
            "KissMVC/FrontControllerBuilder.php",
            "KissMVC/FrontControllerFactoryInterface.php",
            "KissMVC/FrontControllerOptions.php",
            "KissMVC/HeaderEmitterInterface.php",
            "KissMVC/HeadersSentCheckerInterface.php",
            "KissMVC/RedirectTerminatorInterface.php",
            "KissMVC/RequestParametersProviderInterface.php",
            "KissMVC/RouteResolverInterface.php",
            "Controllers/IndexControllerFactory.php",
            "Controllers/PageWithParametersControllerFactory.php",
            "Layouts",
            "Partials",
            "Views",
            "vendor",
        ],
    },
    logs: {
        text: "build/mutation/text.log",
        summary: "build/mutation/summary.log",
        json: "build/mutation/report.json",
        html: "build/mutation/report.html",
    },
    phpUnit: {
        configDir: ".",
    },
    testFramework: "phpunit",
    mutators: {
        "@default": true,
        "PublicVisibility": false,
        "ProtectedVisibility": false,
    },
}
